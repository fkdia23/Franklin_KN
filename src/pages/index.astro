---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import Hr from "@/components/Hr.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
---

<Layout>
  <Header />

  <main id="main-content" data-layout="index">
    <!-- HERO -->
    <section id="hero" class="min-h-150 flex flex-col justify-center mt-15">
      <div class="flex flex-col items-center text-center mb-6 px-4 sm:px-0 ">
        <img
          src="/profile.jpeg"
          alt="Franklin Kana Nguédia"
          class="w-40 h-40 sm:w-48 sm:h-48 rounded-full object-cover ring-2 ring-accent/50 ring-offset-4 ring-offset-background mb-6"
        />
        <h1 class="text-3xl sm:text-5xl font-bold mb-3 mt-3 text-foreground">
          Franklin KANA NGUEDIA
        </h1>
        <p class="text-xl sm:text-2xl font-semibold text-accent mb-4">
          Data Engineer & AI Engineer
        </p>
        <p class="text-lg text-muted-foreground max-w-2xl leading-relaxed">
          Passionné par la donnée, je façonne des architectures complexes en solutions
          vivantes, <strong class="text-foreground">performantes et maîtrisées côté coûts (FinOps)</strong>.
          Je donne vie à des pipelines Airflow, des systèmes RAG et des graphes Neo4j —
          animé par le suivi des métriques et l'observabilité de bout en bout.
        </p>

        <ul class="mt-6 flex flex-wrap justify-center gap-2">
          {
            ["Airflow", "Azure / Databricks", "Spark", "RAG / LLMs", "Neo4j", "Docker / K8s", "FinOps", "Observabilité"].map(
              stack => (
                <li class="rounded-full border border-border px-3 py-1 text-xs text-muted-foreground">
                  {stack}
                </li>
              )
            )
          }
        </ul>

        <div class="mt-7 flex flex-wrap justify-center gap-3">
          <a
            href="/posts/"
            class="rounded-md bg-accent px-5 py-2.5 text-sm font-medium text-background transition hover:opacity-90"
          >
            Voir mes projets
            <IconArrowRight class="inline-block rtl:-rotate-180" />
          </a>
          <a
            href="/about/"
            class="rounded-md border border-border px-5 py-2.5 text-sm font-medium transition hover:border-accent hover:text-accent"
          >
            À propos de moi
          </a>
        </div>
      </div>
      {
        SOCIALS.length > 0 && (
          <div class="flex justify-center items-center gap-2 text-sm text-muted-foreground">
            <span>Me retrouver :</span>
            <Socials />
          </div>
        )
      }
    </section>

    <!-- PROJECTS -->
    {
      sortedPosts.length > 0 && (
        <section id="projects" class="py-8">
          <h2 class="text-2xl font-semibold tracking-wide mb-1">Mes dernières projets</h2>
          {/* <p class="mb-6 text-sm text-muted-foreground">
            Des projets que je construis par passion, jusqu'à la mise en production.
          </p> */}
          <ul>
            {sortedPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && (
                  <Card variant="h3" {...data} />
                )
            )}
          </ul>
          <div class="mt-8 text-center">
            <LinkButton href="/posts/">
              Voir tous les projets
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
          </div>
        </section>
      )
    }


  </main>

  <!-- <Footer /> -->
</Layout>


<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>

---
import type { MarkdownHeading } from "astro";

interface Props {
  headings: MarkdownHeading[];
  /** Classes du conteneur (positionnement géré par le parent) */
  class?: string;
  /** Affiche le titre interne « Sur cette page » */
  heading?: boolean;
}

const { headings, class: className = "", heading = true } = Astro.props;

// On ne garde que les niveaux h2 → h4 pour un sommaire épuré
const toc = headings.filter(h => h.depth >= 2 && h.depth <= 4);
const minDepth = toc.length ? Math.min(...toc.map(h => h.depth)) : 2;
---

{
  toc.length > 0 && (
    <nav
      aria-label="Sommaire"
      data-pagefind-ignore
      class:list={["toc text-sm", className]}
    >
      {
        heading && (
          <h2 class="mb-3 text-xs font-semibold tracking-wide text-muted-foreground uppercase">
            Sur cette page
          </h2>
        )
      }
      <ul class="space-y-1 border-s border-border">
        {toc.map(h => (
          <li style={`--toc-indent:${(h.depth - minDepth) * 0.75}rem`}>
            <a
              href={`#${h.slug}`}
              data-toc-link={h.slug}
              class="-ms-px block border-s border-transparent py-1 ps-[calc(0.75rem+var(--toc-indent))] text-muted-foreground transition-colors hover:text-foreground"
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}
